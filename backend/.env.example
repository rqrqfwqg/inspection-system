# 巡查系统 - 后端环境变量模板
# 复制此文件为 .env 并修改实际值

# JWT 密钥（必填，生产环境请生成强随机密钥）
JWT_SECRET_KEY=change-me-in-production

# 管理员初始密码（仅首次创建管理员时使用）
ADMIN_INIT_PASSWORD=ChangeMe123!

# 开发模式：true 时跳过 JWT 认证
DEV_MODE=false

# 取消登录（内网开放 / 自动 admin）：true 时所有受保护接口在无登录态时
# 自动视为 admin。与 DEV_MODE 任一为真即进入免鉴权模式（AUTH_DISABLED）。
# 生产部署建议设为 true（内网开放、无需登录）。
DISABLE_AUTH=false

# 数据库连接（SQLite 默认，生产建议 PostgreSQL）
# DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/inspection

# 服务端口
PORT=9527
